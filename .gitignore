```gitignore
# Dependencies
node_modules/
.pnp
.pnp.js

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime files
pids
*.pid
*.seed
*.pid.lock

# Build folders
dist/
build/
coverage/

# Vite
vite.svg

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Prisma generated files (optional keep if needed)
node_modules/.prisma/

# Cache
.cache/
.parcel-cache/
.eslintcache

# Temporary files
tmp/
temp/

# Uploads
uploads/

# Mac resource fork files
._*

# Backend specific
backend/.env
backend/node_modules/
backend/dist/

# Frontend specific
frontend/.env
frontend/node_modules/
frontend/dist/
```
